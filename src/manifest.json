{
  "manifest_version": 3,
  "name": "LENS On-chain Intelligence",
  "version": "2.27.66",
  "description": "See everything on-chain. Bankrbot tokens, dev sold, fee claimed, and smart followers, injected directly into Twitter/X profiles.",
  "permissions": ["storage", "alarms", "notifications"],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://api.github.com/*",
    "https://base-mainnet.g.alchemy.com/*",
    "https://api.bankr.bot/*",
    "https://lnsx.io/*",
    "https://lens-liard.vercel.app/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["src/content.js"],
      "css": ["src/lens.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "src/background.js"
  }
}
